# Anything in here is excluded from the npm tarball.
# npm normally falls back to .gitignore when there's no .npmignore; once this
# file exists, npm uses ONLY this list, so be exhaustive about cruft we never
# want to ship to users.

# Runtime state generated by `dvaa --api` — agent Ed25519 identities (with
# secret keys), audit logs, web_fetch cache. NEVER ship. Each install must
# generate its own per-agent identity on first run.
.dvaa-aim/

# Pre-push review marker from the local quality gate. Single-use, 10-min TTL.
# 0.8.2 leaked this; 0.9.0 stops shipping it.
.pre-push-review-passed
.release-test-passed

# Dev-only test suite. Tests run in CI from the repo; users don't need them.
test/

# AI/editor tool config — never ship (also kept out of git via .git/info/exclude).
.claude/
CLAUDE.md
AGENTS.md
.cursorrules
.aider*
.copilot/

# Internal status / release artifacts
STATUS.md
*.tgz

# CI / build / IDE noise
.github/
.DS_Store
.idea/
.vscode/
node_modules/

# Docker-compose dev override (if present)
docker-compose.override.yml
