# VulnBank Workshop — Participant Setup
# ----------------------------------------
# 1. Get a free Groq API key at https://console.groq.com
# 2. Copy this file:  cp .env.example .env
# 3. Paste your key below and save

GROQ_API_KEY=gsk_...

# Optional: override the default LLM model
# GROQ_MODEL=llama-3.3-70b-versatile

# =========================================================
# Blue Team Defense Module Secrets
# =========================================================

# --- Identity Verifier (Ed25519 key pairs for A2A agent signing) ---
# Base64-encoded Ed25519 private key for signing agent identity tokens
AGENT_SIGNING_PRIVATE_KEY=base64-ed25519-private-key-here

# Base64-encoded Ed25519 public key for verifying agent identity tokens
AGENT_SIGNING_PUBLIC_KEY=base64-ed25519-public-key-here

# --- Tool Registry Verifier ---
# Base64-encoded public key of the registry authority used to verify tool manifest signatures
TOOL_REGISTRY_AUTHORITY_PUBLIC_KEY=base64-registry-authority-public-key-here

# --- Secrets Manager / Application Credentials ---
# Database connection string for VulnBank persistent storage
DATABASE_URL=postgresql://user:password@localhost:5432/vulnbank

# Admin password for workshop management endpoints
ADMIN_PASSWORD=your-admin-password-here

# Session signing secret used for HMAC-based session tokens
SESSION_SECRET=your-session-secret-here

# --- LLM API Keys ---
# (GROQ_API_KEY is defined above)
# Optional: secondary LLM provider API key
# OPENAI_API_KEY=sk-your-openai-key-here

# --- Audit Logger ---
# File path for the structured NDJSON audit log output
AUDIT_LOG_FILE_PATH=./logs/audit.log

# Minimum log level: DEBUG, INFO, WARN, ERROR (default: INFO)
AUDIT_LOG_LEVEL=INFO

# --- Defense Orchestrator ---
# Bank profile mode: "participant" (no defenses) or "demo" (defenses active)
BANK_PROFILE=participant

# Per-level hardening toggles (on/off) — only active when BANK_PROFILE=demo
HARDEN_L1=off
HARDEN_L2=off
HARDEN_L3=off
HARDEN_L4=off
HARDEN_L5=off

# AIM (Agent Identity Management) enforcement toggle
AIM_ENFORCEMENT=on
